{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ecs-fargate", "web"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Web Service Usage Statistics",
  "uid": "ecs-web-service",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "targets": [{"expr": "sum(rate(web_requests_total[5m]))", "legendFormat": "req/s", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 80}]}
        }
      },
      "targets": [{"expr": "web_active_connections", "legendFormat": "Active", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate (5xx)",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}
        }
      },
      "targets": [{"expr": "sum(rate(web_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(web_requests_total[5m]))", "legendFormat": "5xx Rate", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "P95 Latency",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1}]}
        }
      },
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(web_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Requests (1h)",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "targets": [{"expr": "sum(increase(web_requests_total[1h]))", "legendFormat": "Total", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Traffic",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requests/sec by Status Code",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}}},
      "targets": [
        {"expr": "sum(rate(web_requests_total[5m])) by (status_code)", "legendFormat": "HTTP {{status_code}}", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Requests/sec by Endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}}},
      "targets": [
        {"expr": "sum(rate(web_requests_total[5m])) by (endpoint)", "legendFormat": "{{endpoint}}", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Latency",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Response Time Percentiles",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(web_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}},
        {"expr": "histogram_quantile(0.90, sum(rate(web_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P90", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}},
        {"expr": "histogram_quantile(0.95, sum(rate(web_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}},
        {"expr": "histogram_quantile(0.99, sum(rate(web_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Response Time by Endpoint (P95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(web_request_duration_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "{{endpoint}}", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Errors",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "collapsed": false
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Error Rate Over Time",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "custom": {"lineWidth": 2},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.05}]},
          "color": {"mode": "fixed", "fixedColor": "red"}
        }
      },
      "targets": [
        {"expr": "sum(rate(web_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(web_requests_total[5m]))", "legendFormat": "5xx Error Rate", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}},
        {"expr": "sum(rate(web_requests_total{status_code=~\"4..\"}[5m])) / sum(rate(web_requests_total[5m]))", "legendFormat": "4xx Error Rate", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Active Connections Over Time",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}, "color": {"mode": "fixed", "fixedColor": "blue"}}},
      "targets": [
        {"expr": "web_active_connections", "legendFormat": "Active Connections", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    }
  ]
}
