{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ecs-fargate", "llm", "ollama"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "LLM Service Performance",
  "uid": "ecs-llm-performance",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ollama Status",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{"expr": "up{job=\"ollama\"}", "legendFormat": "Status", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total LLM Requests",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "targets": [{"expr": "sum(llm_requests_total)", "legendFormat": "Total", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Success Rate",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.9}, {"color": "green", "value": 0.99}]}
        }
      },
      "targets": [{"expr": "sum(rate(llm_requests_total{status=\"success\"}[5m])) / sum(rate(llm_requests_total[5m]))", "legendFormat": "Success Rate", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "P95 Response Time",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 15}, {"color": "red", "value": 30}]}
        }
      },
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Avg Response Time",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 20}]}
        }
      },
      "targets": [{"expr": "sum(rate(llm_request_duration_seconds_sum[5m])) / sum(rate(llm_request_duration_seconds_count[5m]))", "legendFormat": "Avg", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Request Rates",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "LLM Request Rate by Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}}},
      "targets": [
        {"expr": "sum(rate(llm_requests_total[5m])) by (status)", "legendFormat": "{{status}}", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "LLM Request Rate by Model",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}}},
      "targets": [
        {"expr": "sum(rate(llm_requests_total[5m])) by (model)", "legendFormat": "{{model}}", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Latency",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "LLM Response Latency Percentiles",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 15},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}},
        {"expr": "histogram_quantile(0.90, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P90", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}},
        {"expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}},
        {"expr": "histogram_quantile(0.99, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 12,
      "type": "row",
      "title": "Error Analysis",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "collapsed": false
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "LLM Error Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "custom": {"lineWidth": 2},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.05}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [
        {"expr": "sum(rate(llm_requests_total{status=\"error\"}[5m])) / sum(rate(llm_requests_total[5m]))", "legendFormat": "Error Rate", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Cumulative LLM Requests by Model",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}}},
      "targets": [
        {"expr": "sum(llm_requests_total) by (model)", "legendFormat": "{{model}}", "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}}
      ]
    }
  ]
}
